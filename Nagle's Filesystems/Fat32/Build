#Settings
secsz=$((0x200))    #Sector size in bytes
disksz=$((0x20000)) #Disk sectors
partsz=$((0x18000)) #FAT  sectors
fatspc=$((0x01))    #FAT  sectors per cluster

nasm src/Fat32.asm -dsecs=$partsz -dbps=$secsz -dspc=$fatspc -o builds/Fat32  #Generate the filesystem
dd if=/dev/zero status=none of=builds/Fat32 bs=512 count=1 seek=$((disksz-1)) #Pad the file